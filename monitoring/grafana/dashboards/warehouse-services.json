{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Targets up",
      "id": 1,
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "color": {"mode": "thresholds"},
          "unit": "short"
        }
      },
      "targets": [
        {"expr": "up{job=~\"warehouse-.*\"}", "legendFormat": "{{job}}", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Total RPS (all services)",
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      },
      "targets": [
        {"expr": "sum by (service) (rate(http_requests_total[1m]))", "legendFormat": "{{service}}", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Error rate (5m)",
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total{status=~\"5..|4..\"}[5m])) / clamp_min(sum by (service) (rate(http_requests_total[5m])), 1)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p95 latency (5m)",
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 1.0}]}
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Throughput - HTTP requests per second by service & endpoint",
      "id": 5,
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}}},
      "targets": [
        {
          "expr": "sum by (service, endpoint) (rate(http_requests_total[1m]))",
          "legendFormat": "{{service}} {{endpoint}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Latency percentiles (p50 / p95 / p99) by service",
      "id": 6,
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0}}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (service, le) (rate(http_request_duration_seconds_bucket[1m])))", "legendFormat": "p50 {{service}}", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_request_duration_seconds_bucket[1m])))", "legendFormat": "p95 {{service}}", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (service, le) (rate(http_request_duration_seconds_bucket[1m])))", "legendFormat": "p99 {{service}}", "refId": "C"}
      ]
    },

    {
      "type": "timeseries",
      "title": "Error rate (rate of 4xx + 5xx / total) by service",
      "id": 7,
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total{status=~\"5..|4..\"}[1m])) / clamp_min(sum by (service) (rate(http_requests_total[1m])), 1)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "heatmap",
      "title": "Latency heatmap (http_request_duration_seconds, all services)",
      "id": 8,
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "options": {
        "calculate": false,
        "yAxis": {"axisLabel": "duration", "unit": "s"},
        "color": {"mode": "scheme", "scheme": "Spectral", "steps": 64},
        "tooltip": {"mode": "single", "showColorScale": true},
        "legend": {"show": true}
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "{{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "HTTP errors per second by error_type (http_request_errors_total)",
      "id": 9,
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum", "max", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "fillOpacity": 80}}},
      "targets": [
        {
          "expr": "sum by (service, error_type) (rate(http_request_errors_total[1m]))",
          "legendFormat": "{{service}} - {{error_type}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["warehouse", "services", "http"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
